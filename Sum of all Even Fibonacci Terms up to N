import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();

        int a = 0, b = 1;
        int sum = 0;

        while (a <= N) {
           
            if (a % 2 == 0) {
                sum += a;
            }

            int next = a + b;
            a = b;
            b = next;
        }

        System.out.println(sum);

        sc.close();
    }
}
