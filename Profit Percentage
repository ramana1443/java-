import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int cp = sc.nextInt();
        int sp = sc.nextInt();

        double profitPercentage = ((sp - cp) * 100.0) / cp;

        System.out.printf("%.2f", profitPercentage);
    }
}
