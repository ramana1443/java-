import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int N = sc.nextInt();
        int original = N;

      
        int digits = String.valueOf(N).length();

        int sum = 0;

     
        while (N > 0) {
            int digit = N % 10;
            sum += Math.pow(digit, digits);
            N /= 10;
        }

        
        if (sum == original) {
            System.out.println("YES");
        } else {
            System.out.println("NO");
        }

        sc.close();
    }
}
